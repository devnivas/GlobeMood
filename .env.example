# News API Keys Configuration

# NewsAPI (https://newsapi.org)
# Get your free API key at: https://newsapi.org/register
# Free tier includes: 250 requests per day, top headlines from 50+ countries
VITE_NEWS_API_KEY=your_newsapi_key_here

# GNews API (Optional alternative, https://gnews.io)
# Get your free API key at: https://gnews.io
# Free tier includes: 10 requests per day, 100 articles per request
VITE_GNEWS_API_KEY=your_gnews_api_key_here
